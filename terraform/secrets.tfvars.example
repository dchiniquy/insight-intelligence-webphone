# TWILIO SECRETS - Copy this file to secrets.tfvars and fill in your actual values
# DO NOT commit secrets.tfvars to git (it's already in .gitignore)

# Your email for OCIR
ocir_username = "your.email@example.com"

# Twilio Configuration - Replace with your actual credentials
twilio_numbers = {
  personal = {
    phone_number    = "+1234567890"     # Your first Twilio number
    friendly_name   = "Personal Line"
    account_sid     = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # From Twilio Console Dashboard
    auth_token      = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"    # From Twilio Console Dashboard  
    api_key        = "SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"    # Create at: Account → API keys & tokens
    api_secret     = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"     # Secret from API key creation
    twiml_app_sid  = "APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"    # Create at: Console → Voice → TwiML → TwiML Apps
    capabilities = {
      voice = true
      sms   = true
      mms   = true
    }
  }
  
  business = {
    phone_number    = "+1234567891"     # Your second Twilio number
    friendly_name   = "Business Line" 
    account_sid     = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    auth_token      = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    api_key        = "SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    api_secret     = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" 
    twiml_app_sid  = "APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    capabilities = {
      voice = true
      sms   = true
      mms   = false
    }
  }
  
  testing = {
    phone_number    = "+1234567892"     # Your third Twilio number
    friendly_name   = "Testing Line"
    account_sid     = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    auth_token      = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    api_key        = "SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    api_secret     = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    twiml_app_sid  = "APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" 
    capabilities = {
      voice = true
      sms   = true
      mms   = true
    }
  }
}